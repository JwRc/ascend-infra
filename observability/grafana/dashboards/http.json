{
  "id": 123456,
  "uid": "http-status-codes",
  "title": "HTTP Status Codes - Backend",
  "tags": ["backend", "http", "status-codes"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requisições / seg (total)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "% 2xx (Sucesso)",
      "gridPos": { "h": 5, "w": 4, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{status_code=~\"2..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "2xx",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "% 4xx (Erro do cliente)",
      "gridPos": { "h": 5, "w": 4, "x": 10, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{status_code=~\"4..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "4xx",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 15 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "% 5xx (Erro do servidor)",
      "gridPos": { "h": 5, "w": 4, "x": 14, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "5xx",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Taxa de erro geral (4xx + 5xx)",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{status_code=~\"4..|5..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "erro %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requisições por classe de status (2xx/3xx/4xx/5xx)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"2..\"}[5m]))",
          "legendFormat": "2xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"3..\"}[5m]))",
          "legendFormat": "3xx",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"4..\"}[5m]))",
          "legendFormat": "4xx",
          "refId": "C"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 30,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "2xx" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "green" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "3xx" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "blue" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "orange" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "red" }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Códigos específicos (401, 404, 429, 500, 502, 503)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=\"401\"}[5m]))",
          "legendFormat": "401 Unauthorized",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=\"404\"}[5m]))",
          "legendFormat": "404 Not Found",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=\"429\"}[5m]))",
          "legendFormat": "429 Too Many Requests",
          "refId": "C"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=\"500\"}[5m]))",
          "legendFormat": "500 Internal Error",
          "refId": "D"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=\"502\"}[5m]))",
          "legendFormat": "502 Bad Gateway",
          "refId": "E"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=\"503\"}[5m]))",
          "legendFormat": "503 Unavailable",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Breakdown por rota + status code (total desde o início)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(http_requests_total) by (route, method, status_code)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "route": "Rota",
              "method": "Método",
              "status_code": "Status",
              "Value": "Total (1h)"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 400 },
                    { "color": "red", "value": 500 }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
