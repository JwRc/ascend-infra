# Token usado pelo Prometheus para autenticar no /metrics do backend
METRICS_TOKEN=changeme

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# UID do datasource "Prometheus" no Grafana (datasources.yml, rules.yml e dashboards JSON)
PROMETHEUS_DATASOURCE_UID=prometheus

# Slack (contact point de alertas)
SLACK_WEBHOOK_URL=
