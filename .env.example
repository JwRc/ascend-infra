# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=ascend
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme

# ── Auth (better-auth) ─────────────────────────────────────
BETTER_AUTH_SECRET=changeme_use_openssl_rand_base64_32
BETTER_AUTH_URL=http://localhost

# ── Google OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Apple OAuth ────────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── Notificações ───────────────────────────────────────────
FCM_SERVER_KEY=
RESEND_API_KEY=
EMAIL_FROM=noreply@ascend.app

# ── CORS: origins permitidas (separadas por vírgula) ───────
TRUSTED_ORIGINS=http://localhost

# ── Portas expostas pelo nginx (opcional) ──────────────────
HTTP_PORT=80
HTTPS_PORT=443
