# ── Imagens ────────────────────────────────────────────────
# Prefixo do registry (ex: ghcr.io/sua-org/). Deixe vazio para imagens locais.
REGISTRY=
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=ascentio
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme

# ── Auth (better-auth) ─────────────────────────────────────
BETTER_AUTH_SECRET=changeme_use_openssl_rand_base64_32
BETTER_AUTH_URL=http://localhost

# ── Métricas (Prometheus) ──────────────────────────────────
# Precisa bater com o bearer_token em infra/observability/prometheus/prometheus.yml
METRICS_TOKEN=changeme

# ── Google OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Apple OAuth ────────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── Notificações ───────────────────────────────────────────
FCM_SERVER_KEY=
RESEND_API_KEY=
EMAIL_FROM=noreply@ascentio.com.br

# ── CORS: origins permitidas (separadas por vírgula) ───────
TRUSTED_ORIGINS=http://localhost

# ── Stripe (chave pública do frontend) ────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_

# ── Request Tracker (Suporte) ──────────────────────────────
# RT_BASE_URL não é configurável aqui — é sempre http://request-tracker:8080
# (nome do serviço na rede interna do compose), fixo em docker-compose.yml.
# RT_DB_* provisiona o banco do RT dentro do Postgres compartilhado (só tem
# efeito na primeira subida, com o volume pgdata vazio — ver postgres-init/).
RT_DB_NAME=rt_database
RT_DB_USER=rt_user
RT_DB_PASSWORD=changeme
# Senha do usuário root/admin do RT (setada no primeiro boot do container).
RT_ROOT_PASSWORD=changeme
# Credenciais do usuário de serviço que o backend usa para chamar a REST API
# do RT — criado por ./rt-setup.sh, não pela imagem do RT.
RT_API_USER=ascentio-backend
RT_API_PASSWORD=changeme
RT_QUEUE=Support
RT_TENANT_CUSTOM_FIELD=Tenant
# Porta do RT no host, só em loopback (127.0.0.1) — usada por ./rt-setup.sh
# e para abrir a UI via túnel SSH; nunca exposta publicamente pelo nginx.
REQUEST_TRACKER_PORT=8080

# ── Slack (alerta de novo ticket de suporte via Incoming Webhook) ─
SLACK_SUPPORT_WEBHOOK_URL=

# ── Portas expostas pelo nginx ─────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
